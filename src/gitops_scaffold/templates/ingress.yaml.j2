# Generated by gitops-scaffold. Review before applying — see README.md.
# Ingress generation was explicitly requested via --ingress-host/--ingress-class/--tls-secret/--cluster-issuer.
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: {{ resource_name }}
  namespace: {{ namespace | tojson }}
  labels:
{% for key, value in labels.items() %}
    {{ key }}: {{ value | tojson }}
{% endfor %}
  annotations:
    cert-manager.io/cluster-issuer: {{ cluster_issuer | tojson }}
spec:
  ingressClassName: {{ ingress_class | tojson }}
  tls:
    - hosts:
        - {{ host | tojson }}
      secretName: {{ tls_secret | tojson }}
  rules:
    - host: {{ host | tojson }}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: {{ service_name | tojson }}
                port:
                  name: {{ port_name | tojson }}
