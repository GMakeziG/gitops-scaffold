# Generated by gitops-scaffold. Review before applying — see VALIDATION_CHECKLIST.md.
apiVersion: v1
kind: Service
metadata:
  name: {{ service.name }}
  namespace: {{ namespace }}
  labels:
    app.kubernetes.io/name: {{ service.name }}
    app.kubernetes.io/part-of: {{ app.name }}
    app.kubernetes.io/managed-by: gitops-scaffold
spec:
  selector:
    app.kubernetes.io/name: {{ service.name }}
  ports:
{% for port in service.ports %}
    - name: {{ port.name or (port.container_port | string) }}
      port: {{ port.container_port }}
      targetPort: {{ port.container_port }}
      protocol: {{ port.protocol.value }}
{% endfor %}
