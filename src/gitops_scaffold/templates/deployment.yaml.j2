# Generated by gitops-scaffold. Review before applying — see VALIDATION_CHECKLIST.md.
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ service.name }}
  namespace: {{ namespace }}
  labels:
    app.kubernetes.io/name: {{ service.name }}
    app.kubernetes.io/part-of: {{ app.name }}
    app.kubernetes.io/managed-by: gitops-scaffold
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: {{ service.name }}
  template:
    metadata:
      labels:
        app.kubernetes.io/name: {{ service.name }}
        app.kubernetes.io/part-of: {{ app.name }}
    spec:
{% if runtime_user %}
      securityContext:
        runAsUser: {{ runtime_user.uid }}
        runAsGroup: {{ runtime_user.gid }}
        runAsNonRoot: true
{% else %}
      # REVIEW REQUIRED: runtime user could not be determined. Set securityContext explicitly.
{% endif %}
      containers:
        - name: {{ service.name }}
          image: {{ service.image }}
          imagePullPolicy: {{ image_pull_policy }}
{% if service.ports %}
          ports:
{% for port in service.ports %}
            - containerPort: {{ port.container_port }}
              protocol: {{ port.protocol.value }}
{% endfor %}
{% endif %}
{% if health_check_path %}
          readinessProbe:
            httpGet:
              path: {{ health_check_path }}
              port: {{ health_check_port }}
{% else %}
          # TODO: no health check endpoint was detected. Add a readiness/liveness probe manually.
{% endif %}
