{# Rendered by generators/kustomize/pvc.py. One PersistentVolumeClaim
   document per planned PVC (see generators/volumes.py), separated by `---`
   when a service (or the shared root) has more than one. #}
{% for pvc in pvcs %}
{% if not loop.first %}
---
{% endif %}
# Generated by gitops-scaffold. Review before applying — see README.md.
# Source: {{ pvc.source_description }}
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: {{ pvc.name }}
  namespace: {{ namespace | tojson }}
  labels:
{% for key, value in pvc.labels.items() %}
    {{ key }}: {{ value | tojson }}
{% endfor %}
spec:
  accessModes:
    - {{ access_mode }}
  resources:
    requests:
      # REVIEW REQUIRED: storage size could not be inferred from the Compose
      # definition -- Compose has no size concept at all. Defaulted to
      # {{ size }}; set the real capacity your workload needs.
      storage: {{ size | tojson }}
{% endfor %}
